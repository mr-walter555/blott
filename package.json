{
  "name": "smart-notepad",
  "version": "1.0.15",
  "private": true,
  "description": "AI-powered smart notepad desktop application",
  "author": "mr-walter555",
  "main": "electron/main.js",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "concurrently -n electron,vite -c blue,green \"npm run electron:dev\" \"npm run dev:web\"",
    "dev:web": "vite",
    "electron:dev": "wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .",
    "build": "vite build",
    "preview": "vite preview",
    "electron:build": "electron-builder",
    "release": "npm run build && electron-builder --publish always",
    "start": "electron .",
    "patch-icon": "node scripts/patch-electron-icon.js"
  },
  "dependencies": {
    "electron-context-menu": "^3.6.1",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.8.9",
    "openai": "^4.20.1",
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/sora": "^5.2.8",
    "@phosphor-icons/react": "^2.1.10",
    "@tiptap/extension-character-count": "^2.1.13",
    "@tiptap/extension-code-block-lowlight": "^2.27.2",
    "@tiptap/extension-color": "^2.1.13",
    "@tiptap/extension-highlight": "^2.1.13",
    "@tiptap/extension-image": "^2.27.2",
    "@tiptap/extension-link": "^2.1.13",
    "@tiptap/extension-placeholder": "^2.1.13",
    "@tiptap/extension-task-item": "^2.1.13",
    "@tiptap/extension-task-list": "^2.1.13",
    "@tiptap/extension-text-align": "^2.27.2",
    "@tiptap/extension-text-style": "^2.1.13",
    "@tiptap/extension-underline": "^2.1.13",
    "@tiptap/react": "^2.1.13",
    "@tiptap/starter-kit": "^2.1.13",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "clsx": "^2.0.0",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "date-fns": "^2.30.0",
    "dompurify": "^3.4.8",
    "electron": "^27.1.3",
    "electron-builder": "^24.6.4",
    "framer-motion": "^10.16.16",
    "gsap": "^3.15.0",
    "jimp": "^1.6.1",
    "lowlight": "^3.3.0",
    "lucide-react": "^0.294.0",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.4.32",
    "rcedit": "^5.0.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.6.0",
    "tailwindcss": "^3.3.6",
    "vite": "^5.0.6",
    "wait-on": "^7.2.0",
    "zustand": "^4.4.7"
  },
  "build": {
    "appId": "com.smart-notepad.app",
    "productName": "Smart Notepad",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "dist/**/*",
      "shared/**/*",
      "package.json"
    ],
    "electronLanguages": [
      "en-US"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    },
    "publish": {
      "provider": "github",
      "owner": "mr-walter555",
      "repo": "smart-notepad",
      "releaseType": "release"
    }
  }
}
